# ============================================
# LNMP Platform - Environment Configuration
# ============================================
# Copy this file to .env and adjust values:
#   cp .env.example .env

# --- Environment ---
APP_ENV=dev

# --- Nginx ---
NGINX_PORT=80
NGINX_SSL_PORT=443

# --- PHP ---
PHP_DISPLAY_ERRORS=On
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=30
PHP_POST_MAX_SIZE=50M
PHP_UPLOAD_MAX_FILESIZE=50M

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=app
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass
MYSQL_PORT=3306

# --- Redis ---
REDIS_PASSWORD=redispass
REDIS_PORT=6379

# --- Domain ---
APP_DOMAIN=localhost

# --- Logging ---
LOG_LEVEL=debug

# --- Elasticsearch ---
ES_JVM_HEAP=256m
ES_PORT=9200

# --- Kibana ---
KIBANA_PORT=5601

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Alertmanager ---
ALERTMANAGER_PORT=9093

# --- Webhook (Feishu/DingTalk placeholder) ---
ALERT_WEBHOOK_URL=http://webhook:5000/
